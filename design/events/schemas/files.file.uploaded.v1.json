{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.platform/files.file.uploaded.v1.json",
  "title": "files.file.uploaded.v1 data",
  "type": "object",
  "required": ["file_id", "content_type", "size_bytes", "storage_key"],
  "properties": {
    "file_id": { "type": "string", "format": "uuid" },
    "content_type": { "type": "string" },
    "size_bytes": { "type": "integer", "minimum": 0 },
    "storage_key": { "type": "string", "description": "workspace_id/uuid in MinIO" },
    "checksum": { "type": "string" }
  },
  "additionalProperties": false
}
